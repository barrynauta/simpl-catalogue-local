# Simpl Catalogue Local Configuration

# PostgreSQL
POSTGRES_USER=catalogue
POSTGRES_PASSWORD=catalogue_pass
POSTGRES_DB=fc_catalogue
POSTGRES_PORT=5432

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=catalogue_pass
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# fc-service
FC_SERVICE_PORT=8081

# xfsc-advsearch-be
ADVSEARCH_PORT=8080
ADVSEARCH_VERSION=1.20.0

# catalogue-client (UI)
CATALOGUE_UI_PORT=4321

# Build settings
BUILD_SKIP_TESTS=true
